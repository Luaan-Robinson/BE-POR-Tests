# ============================================================
# BE POR Automation Test Framework — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
BASE_URL=http://localhost:3000

# ------------------------------------------------------------
# Test User Credentials
# Must be a real account that already exists in the application
# ------------------------------------------------------------
TEST_USER_EMAIL=your-test-user@example.com
TEST_USER_PASSWORD=your-password

# ------------------------------------------------------------
# Database
# Required for DB verification and cleanup steps
# Leave blank to skip all database operations
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/be_por

# ------------------------------------------------------------
# Test Data Cleanup
# CLEANUP_ON_START: delete leftover test data before the run
# CLEANUP_ON_END:   delete test data created during the run
# ------------------------------------------------------------
CLEANUP_ON_START=false
CLEANUP_ON_END=true

# ------------------------------------------------------------
# Logging
# Set to true to enable verbose debug output
# ------------------------------------------------------------
DEBUG=false

# ------------------------------------------------------------
# Environment (optional)
# Controls which URL set is used from config/environments.ts
# Options: dev | staging | production   (default: dev)
# ------------------------------------------------------------
# TEST_ENV=dev

# ------------------------------------------------------------
# Additional environment URLs (optional)
# Only needed if TEST_ENV is set to staging or production
# ------------------------------------------------------------
# STAGING_URL=https://staging.example.com
# STAGING_API_URL=https://staging.example.com/api
# PROD_URL=https://example.com
# PROD_API_URL=https://example.com/api